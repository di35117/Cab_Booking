# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ride_pooling?schema=public&connection_limit=20&pool_timeout=20"

# Redis
REDIS_HOST="localhost"
REDIS_PORT=6379

# Server
PORT=3000
NODE_ENV="development"

# Matching Configuration
MAX_POOL_SIZE=4
MAX_LUGGAGE_PER_POOL=6
MAX_DETOUR_TOLERANCE_MINS=15
MATCHING_TIMEOUT_MS=5000

# Pricing
BASE_FARE=50
PER_KM_RATE=12
PER_MINUTE_RATE=2
POOL_DISCOUNT=0.30

# Performance
MAX_CONCURRENT_MATCHES=100
QUEUE_CONCURRENCY=10
